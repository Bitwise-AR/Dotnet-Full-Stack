@model CollegeAppMVC.Models.CollegeApplication

<div class="delete-page">
    <div class="delete-card">

        <h2 class="delete-title">Delete Application</h2>
        <p class="delete-warning">
            Are you sure you want to delete this student?
        </p>

        <div class="delete-content">

            <div class="delete-image">
                @if (Model.ProfileImage != null)
                {
                    var base64 = Convert.ToBase64String(Model.ProfileImage);
                    var imgSrc = $"data:image/png;base64,{base64}";
                    <img src="@imgSrc" />
                }
                else
                {
                    <div class="no-image">No Image</div>
                }
            </div>

            <div class="delete-details">
                <h3>@Model.FullName</h3>
                <p>@Model.Email</p>
                <p>@Model.CountryCode @Model.PhoneNumber</p>
                <p>@Model.Course</p>
            </div>

        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="delete-actions">
                <button type="submit" class="btn-danger">
                    Yes, Delete
                </button>

                <a asp-action="Index" class="btn-secondary">
                    Cancel
                </a>
            </div>
        </form>

    </div>
</div>