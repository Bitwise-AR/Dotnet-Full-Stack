@model CollegeAppMVC.Models.CollegeApplication
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial;
        }

        .container {
            width: 100%;
        }

        .title {
            font-size: 22px;
            margin-bottom: 20px;
        }

        .row {
            margin-bottom: 10px;
        }

        .label {
            font-weight: bold;
        }

        img {
            width: 150px;
            height: 150px;
            object-fit: cover;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="title">Student Details</div>

        @if (Model.ProfileImage != null)
        {
            var base64 = Convert.ToBase64String(Model.ProfileImage);
            var imgSrc = $"data:image/png;base64,{base64}";
            <img src="@imgSrc" />
        }

        <div class="row"><span class="label">Name:</span> @Model.FullName</div>
        <div class="row"><span class="label">Email:</span> @Model.Email</div>
        <div class="row"><span class="label">Gender:</span> @Model.Gender</div>
        <div class="row"><span class="label">Phone:</span> @Model.CountryCode @Model.PhoneNumber</div>
        <div class="row"><span class="label">DOB:</span> @Model.DateOfBirth.ToShortDateString()</div>
        <div class="row"><span class="label">Percentage:</span> @Model.Percentage %</div>
        <div class="row"><span class="label">Course:</span> @Model.Course</div>
        <div class="row"><span class="label">Address:</span> @Model.Address</div>
    </div>
</body>
</html>