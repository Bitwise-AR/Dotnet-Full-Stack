@model CollegeAppMVC.Models.CollegeApplication

<div class="page-title">Edit Application</div>

<div style="margin-bottom: 20px;">
    <a asp-action="Index" class="btn-secondary">
        ← Back to Applications
    </a>
</div>

<div class="form-wrapper">
    <form asp-action="Edit" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="All" class="error"></div>

        <div class="form-group">
            <label>Change Image (Optional)</label>
            <input asp-for="ImageFile" type="file" accept=".png,.jpg,.jpeg" />
            <span asp-validation-for="ImageFile" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="FullName"></label>
            <input asp-for="FullName" />
            <span asp-validation-for="FullName" class="error"></span>
        </div>

        <div class="form-group">
            <label>Gender</label>

            <div class="gender-row">
                <label class="radio-option">
                    <input type="radio" asp-for="Gender" value="Male" /> Male
                </label>

                <label class="radio-option">
                    <input type="radio" asp-for="Gender" value="Female" /> Female
                </label>

                <label class="radio-option">
                    <input type="radio" asp-for="Gender" value="Other" /> Other
                </label>
            </div>

            <span asp-validation-for="Gender" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="error"></span>
        </div>

        <!-- Phone -->
        <div class="form-group">
            <label>Phone Number</label>

            <div class="phone-row">
                <select asp-for="CountryCode">
                    <option value="">Select Code</option>
                    <option value="+91">+91 (India)</option>
                    <option value="+1">+1 (USA)</option>
                    <option value="+44">+44 (UK)</option>
                    <option value="+61">+61 (Australia)</option>
                </select>

                <input asp-for="PhoneNumber" maxlength="10" />
            </div>

            <span asp-validation-for="CountryCode" class="error"></span>
            <span asp-validation-for="PhoneNumber" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="DateOfBirth"></label>
            <input asp-for="DateOfBirth" type="date" />
            <span asp-validation-for="DateOfBirth" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Percentage"></label>
            <input asp-for="Percentage" />
            <span asp-validation-for="Percentage" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Course"></label>
            <input asp-for="Course" />
            <span asp-validation-for="Course" class="error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address"></label>
            <textarea asp-for="Address"></textarea>
            <span asp-validation-for="Address" class="error"></span>
        </div>

        <button type="submit" class="btn-primary">
            Update Application
        </button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $("form").validate({
                onfocusout: function (element) {
                    this.element(element);
                },
                onkeyup: false,
                onclick: false
            });
        });
    </script>

    <script>
        const fileInput = document.querySelector('input[type="file"]');

        fileInput.addEventListener("change", function () {

            const file = this.files[0];
            const allowedExtensions = ["jpg", "jpeg", "png"];
            const maxSize = 1 * 1024 * 1024; // 1MB

            if (!file) return;

            const extension = file.name.split('.').pop().toLowerCase();

            if (!allowedExtensions.includes(extension)) {
                alert("Only .jpg, .jpeg, .png files allowed.");
                this.value = "";
                return;
            }

            if (file.size > maxSize) {
                alert("File size must be less than 1MB.");
                this.value = "";
                return;
            }
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const form = document.querySelector("form");
            const fields = Array.from(form.querySelectorAll("input, select, textarea"))
                .filter(el => el.type !== "hidden");

            const isEditPage = window.location.pathname.toLowerCase().includes("edit");

            function isFieldEmpty(field) {

                if (field.type === "radio") {
                    const checked = document.querySelector(`input[name="${field.name}"]:checked`);
                    return !checked;
                }

                // Skip file validation on EDIT page
                if (field.type === "file") {
                    if (isEditPage) return false;
                    return field.files.length === 0;
                }

                return !field.value.trim();
            }

            fields.forEach((field, index) => {

                field.addEventListener("focus", function () {

                    for (let i = 0; i < index; i++) {

                        const previousField = fields[i];

                        if (isFieldEmpty(previousField)) {
                            previousField.classList.add("field-error");
                            previousField.focus();
                            alert("Please complete previous fields first.");
                            return;
                        }
                    }
                });

                field.addEventListener("input", function () {
                    field.classList.remove("field-error");
                });

                field.addEventListener("change", function () {
                    field.classList.remove("field-error");
                });
            });
        });
    </script>
}