@model IEnumerable<CollegeAppMVC.Models.CollegeApplication>

<div class="page-title">College Applications</div>

<a asp-action="Create" class="btn-primary">
    + Create New Application
</a>

<div class="table-container card">
    <table>
        <thead>
            <tr>
                <th>Photo</th>
                <th>Full Name</th>
                <th>Gender</th>
                <th>Email</th>
                <th>Phone</th>
                <th>DOB</th>
                <th>Percentage</th>
                <th>Course</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (item.ProfileImage != null)
                    {
                        var base64 = Convert.ToBase64String(item.ProfileImage);
                        var imgSrc = $"data:image/png;base64,{base64}";
                        <img src="@imgSrc" width="50" height="50" style="border-radius:50%; object-fit:cover;" />
                    }
                </td>
                <td>@item.FullName</td>
                <td>@item.Gender</td>
                <td>@item.Email</td>
                <td>@item.CountryCode @item.PhoneNumber</td>
                <td>@item.DateOfBirth.ToShortDateString()</td>
                <td>@item.Percentage %</td>
                <td>@item.Course</td>
                    <td>
                        <div class="action-buttons">
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-btn info-btn">
                                Details
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn edit-btn">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn delete-btn">
                                Delete
                            </a>
                        </div>
                    </td>
            </tr>
        }
        </tbody>
    </table>
</div>