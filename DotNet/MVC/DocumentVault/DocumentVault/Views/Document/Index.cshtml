@model List<Document>

<h2>Document Vault</h2>

<a href="/Document/Upload">Upload New File</a>

<table border="1" cellpadding="10">
    <thead>
        <tr>
            <th>File Name</th>
            <th>Type</th>
            <th>Size (KB)</th>
            <th>Uploaded By</th>
            <th>Uploaded At</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var doc in Model)
        {
            <tr>
                <td>@doc.FileName</td>
                <td>@doc.ContentType</td>
                <td>@(doc.Size / 1024)</td>
                <td>@doc.UploadedBy</td>
                <td>@doc.UploadedAt.ToLocalTime()</td>
                <td>
                    <a href="/Document/Download/@doc.Id">Download</a>
                </td>
            </tr>
        }
    </tbody>
</table>