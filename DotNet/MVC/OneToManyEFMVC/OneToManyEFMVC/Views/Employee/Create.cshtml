@model OneToManyEFMVC.Models.Employee

<h2>Add Employee</h2>

<form asp-action="Create" method="post">

    <label>Name</label>
    <input asp-for="Name" />

    <br /><br />

    <label>Department</label>
    <select asp-for="DepartmentId" asp-items="ViewBag.Departments"></select>

    <br /><br />

    <button type="submit">Save</button>

</form>