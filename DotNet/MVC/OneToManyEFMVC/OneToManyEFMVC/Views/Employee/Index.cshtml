@model IEnumerable<OneToManyEFMVC.Models.Employee>

<h2>Employees</h2>

<a asp-action="Create">Add Employee</a>

<table border="1">

    <tr>
        <th>Name</th>
        <th>Department</th>
    </tr>

    @foreach (var emp in Model)
    {
        <tr>
            <td>@emp.Name</td>
            <td>@emp.Department.Name</td>
        </tr>
    }

</table>